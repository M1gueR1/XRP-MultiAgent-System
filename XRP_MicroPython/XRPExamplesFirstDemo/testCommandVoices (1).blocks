from EmotionLib import (
    Emotion,
    EmotionDefinition,
    EmotionOutputHub,
    RedVisionEmotionDisplay,
    XPPEmotionPublisher,
)
from XRPLib.board import Board
from EmotionLib.voice_command_receiver import VoiceCommandReceiver
from XRPLib.differential_drive import DifferentialDrive
import time

USE_RED_VISION = True

emotionPublisher = XPPEmotionPublisher()

redVisionEmotionDisplay = (
    RedVisionEmotionDisplay(
        sheets_directory="/emotion_sheets_192",
        custom_sheets_directory="/emotion_sheets_custom",
        strict_assets=False,
        cache_capacity=4,
        debug=False,
        enabled=USE_RED_VISION,
        strict_display=False,
    )
)

emotionOutputs = EmotionOutputHub(
    emotionPublisher.publish_state,
    redVisionEmotionDisplay.apply_state,
    strict=False,
)

emotion = Emotion(
    publisher=emotionOutputs.publish_state,
    min_time_before_switch_ms=0,
)

board = Board.get_default_board()

voiceCommandReceiver = VoiceCommandReceiver()
voiceCommand = None

emotion.register_definition(
    EmotionDefinition(
        name="happy",
        emotion_id=1,
        playback_fps=10,
        frame_subset=None,
        min_time_before_switch_ms=None,
        repeat_mode="ping_pong",
        repeat_count=None,
        flag_overrides=(
            "dashboard_screen",
        ),
    )
)

emotion.register_definition(
    EmotionDefinition(
        name="sad",
        emotion_id=9,
        playback_fps=10,
        frame_subset=None,
        min_time_before_switch_ms=None,
        repeat_mode="ping_pong",
        repeat_count=None,
        flag_overrides=(
            "dashboard_screen",
        ),
    )
)

differentialDrive = DifferentialDrive.get_default_differential_drive()


while not (board.is_button_pressed()):
  voiceCommand = voiceCommandReceiver.poll()
  if voiceCommand == "turn_happy":
    emotion.set_emotion("happy", force_reset=False)
  if voiceCommand == "turn_sad":
    emotion.set_emotion("sad", force_reset=False)
  if voiceCommand == "turn_right":
    differentialDrive.arcade(0, (-0.3))
    time.sleep(0.4)
    differentialDrive.stop()
  if voiceCommand == "turn_left":
    differentialDrive.arcade(0, 0.3)
    time.sleep(0.4)
    differentialDrive.stop()
  if voiceCommand == "turn_back":
    differentialDrive.arcade((-0.25), 0)
    time.sleep(0.4)
    differentialDrive.stop()
  emotion.run_emotion()
  redVisionEmotionDisplay.update()



