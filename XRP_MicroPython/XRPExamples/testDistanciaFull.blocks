from EmotionLib import Emotion, EmotionDefinition, XPPEmotionPublisher
from EmotionLib import EmotionHardwareConfig, EmotionMotionController
from XRPLib.board import Board
from XRPLib.rangefinder import Rangefinder
from XRPLib.differential_drive import DifferentialDrive
import time

distance = None

emotionPublisher = XPPEmotionPublisher()
emotion = Emotion(
    publisher=emotionPublisher.publish_state
)

emotionHardware = EmotionHardwareConfig(
    drive_left_port="L",
    drive_right_port="R",
    invert_left=False,
    invert_right=False,
    aux_motor_1_port=None,
    aux_motor_2_port=None,
    invert_aux_motor_1=False,
    invert_aux_motor_2=False,
    use_imu=True,
)
emotionDrive = emotionHardware.create_drivetrain()
emotionMotion = EmotionMotionController(emotionDrive)
emotion.set_motion_controller(emotionMotion)

emotion.register_definition(
    EmotionDefinition(
        name="happy",
        emotion_id=1,
        playback_fps=None,
        frame_subset=None,
        min_time_before_switch_ms=0,
        repeat_mode="loop",
        repeat_count=None,
        flag_overrides=("dashboard_screen",),
    )
)

emotion.register_definition(
    EmotionDefinition(
        name="frustrated",
        emotion_id=7,
        playback_fps=7,
        frame_subset=None,
        min_time_before_switch_ms=0,
        repeat_mode="loop",
        repeat_count=None,
        flag_overrides=("dashboard_screen", "drivetrain"),
    )
)

emotion.register_definition(
    EmotionDefinition(
        name="sad",
        emotion_id=9,
        playback_fps=3,
        frame_subset=None,
        min_time_before_switch_ms=0,
        repeat_mode="loop",
        repeat_count=None,
        flag_overrides=("dashboard_screen",),
    )
)

board = Board.get_default_board()

rangefinder = Rangefinder.get_default_rangefinder()

differentialDrive = DifferentialDrive.get_default_differential_drive()


emotion.configure_motion(
    "frustrated",
    steps=(
        (130, 0.3, 0.5),
        (130, 0.3, -0.5),
        (110, 0.2, 0.35),
        (110, 0.2, -0.35),
    ),
    repeat=True,
)
while not (board.is_button_pressed()):
  distance = rangefinder.distance()
  if distance <= 5:
    emotion.set_emotion("sad", force_reset=False)
  elif distance <= 15:
    emotion.set_emotion("frustrated", force_reset=False)
  else:
    emotion.set_emotion("happy", force_reset=False)
  emotion.run_emotion()
  if (emotion.is_overriding_drive()) == False:
    if distance > 15:
      differentialDrive.arcade(0.55, 0)
    else:
      differentialDrive.stop()
  time.sleep(0.02)
differentialDrive.stop()



